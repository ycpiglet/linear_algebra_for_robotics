{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Publishing design operations work item",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "title",
    "area",
    "status",
    "priority",
    "change_class",
    "version_impact",
    "owner_role",
    "review_roles",
    "branch",
    "dependencies",
    "decision_refs",
    "decision_needed",
    "blocker",
    "status_reason",
    "superseded_by",
    "scope",
    "change_paths",
    "verification",
    "rollback",
    "definition_of_done",
    "evidence",
    "last_reviewed"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^PUB-[0-9]{3}$" },
    "title": { "type": "string", "minLength": 1 },
    "area": {
      "enum": ["governance", "ci", "identity", "design-system", "artifact", "migration"]
    },
    "status": {
      "enum": [
        "decision",
        "planned",
        "ready",
        "in_progress",
        "in_review",
        "blocked",
        "done",
        "cancelled",
        "superseded",
        "rolled_back"
      ]
    },
    "priority": { "enum": ["P0", "P1", "P2", "P3"] },
    "change_class": {
      "enum": [
        "documentation",
        "governance",
        "toolchain",
        "breaking",
        "foundation",
        "component",
        "migration"
      ]
    },
    "version_impact": { "enum": ["none", "compatible", "additive", "breaking"] },
    "owner_role": { "type": "string", "minLength": 1 },
    "review_roles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "branch": { "type": ["string", "null"], "minLength": 1 },
    "dependencies": {
      "type": "array",
      "items": { "type": "string", "pattern": "^PUB-[0-9]{3}$" },
      "uniqueItems": true
    },
    "decision_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "decision_needed": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "blocker": { "type": ["string", "null"], "minLength": 1 },
    "status_reason": { "type": ["string", "null"], "minLength": 1 },
    "superseded_by": {
      "type": ["string", "null"],
      "pattern": "^PUB-[0-9]{3}$"
    },
    "scope": { "$ref": "#/$defs/scope" },
    "change_paths": { "$ref": "#/$defs/changePaths" },
    "verification": { "$ref": "#/$defs/verification" },
    "rollback": { "$ref": "#/$defs/rollback" },
    "definition_of_done": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence": { "$ref": "#/$defs/evidence" },
    "last_reviewed": { "type": "string", "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}$" }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "scope": {
      "type": "object",
      "required": ["in", "out"],
      "properties": {
        "in": { "$ref": "#/$defs/stringList" },
        "out": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "changePaths": {
      "type": "object",
      "required": ["read", "write", "exclusive_locks", "generated"],
      "properties": {
        "read": { "$ref": "#/$defs/stringList" },
        "write": { "$ref": "#/$defs/stringList" },
        "exclusive_locks": { "$ref": "#/$defs/stringList" },
        "generated": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "verification": {
      "type": "object",
      "required": ["source_contract", "rendered_contract", "post_merge"],
      "properties": {
        "source_contract": { "$ref": "#/$defs/stringList" },
        "rendered_contract": { "$ref": "#/$defs/stringList" },
        "post_merge": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "rollback": {
      "type": "object",
      "required": ["triggers", "unit", "steps", "compatibility_preserved"],
      "properties": {
        "triggers": { "$ref": "#/$defs/stringList" },
        "unit": { "enum": ["merge_commit", "cutover", "batch"] },
        "steps": { "$ref": "#/$defs/stringList" },
        "compatibility_preserved": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": [
        "issue",
        "pr",
        "ci_runs",
        "rendered_artifacts",
        "post_merge",
        "last_known_good",
        "revert_ref",
        "follow_up"
      ],
      "properties": {
        "issue": { "type": ["integer", "null"], "minimum": 1 },
        "pr": { "type": ["integer", "null"], "minimum": 1 },
        "ci_runs": { "$ref": "#/$defs/stringList" },
        "rendered_artifacts": { "$ref": "#/$defs/stringList" },
        "post_merge": { "$ref": "#/$defs/stringList" },
        "last_known_good": { "type": ["string", "null"], "minLength": 1 },
        "revert_ref": { "type": ["string", "null"], "minLength": 1 },
        "follow_up": {
          "type": ["string", "null"],
          "pattern": "^PUB-[0-9]{3}$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
